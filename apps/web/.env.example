# ─── TML Web — Environment Variables ─────────────────────────────────
# Copy this file to .env.local and adjust values as needed:
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────

# ─── API Connection ─────────────────────────────────────────────────
# URL of the TML API backend
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Application ────────────────────────────────────────────────────
# Public-facing URL of this web app
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Internationalization ───────────────────────────────────────────
# Default locale: en | fr | ar | tzm
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# ─── Identity Provider (MOSIP e-Signet) ─────────────────────────────
# Optional — used for client-side OIDC redirect flows
# NEXT_PUBLIC_MOSIP_CLIENT_ID=tml-dev-client
# NEXT_PUBLIC_MOSIP_ISSUER_URL=https://esignet.example.com
